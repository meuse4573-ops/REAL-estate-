# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dealbot

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Auth
SECRET_KEY=your-jwt-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gmail OAuth
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/emails/callback/gmail

# Outlook OAuth
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-client-secret
OUTLOOK_REDIRECT_URI=http://localhost:8000/emails/callback/outlook

# CRM
FOLLOWUPBOSS_API_KEY=optional-for-now

# Notifications
SLACK_WEBHOOK_URL=optional-for-now

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000